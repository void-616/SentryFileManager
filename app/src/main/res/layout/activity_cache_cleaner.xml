<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView
        android:id="@+id/cleaner_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:textAppearance="?textAppearanceBody2"
        android:textColor="?colorPrimary"
        android:visibility="gone" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?dividerColor" />

    <TextView
        android:id="@+id/cleaner_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="No folders watched\nTap + to add a folder"
        android:textAppearance="?textAppearanceBody1"
        android:textColor="?android:textColorSecondary"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/cleaner_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="80dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="end">

        <Button
            android:id="@+id/btn_add_folder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add folder"
            style="?borderlessButtonStyle"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_clean_now"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clean now" />

    </LinearLayout>

</LinearLayout>
