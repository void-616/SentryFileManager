<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <!-- Title bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#1A1A1A"
        android:paddingStart="12dp"
        android:paddingEnd="4dp">

        <TextView
            android:id="@+id/terminal_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Terminal"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/btn_terminal_paste"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="Paste"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?selectableItemBackground" />

        <TextView
            android:id="@+id/btn_terminal_close"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="✕"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?selectableItemBackground" />

    </LinearLayout>

    <!-- Terminal view -->
    <com.termux.view.TerminalView
        android:id="@+id/terminal_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:focusable="true"
        android:focusableInTouchMode="true" />

    <!-- Key bar -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="#1A1A1A"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/key_bar"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="4dp">

            <TextView android:id="@+id/key_esc"
                android:layout_width="wrap_content" android:layout_height="match_parent"
                android:text="ESC" android:textColor="#CCCCCC" android:textSize="11sp"
                android:gravity="center" android:paddingHorizontal="12dp"
                android:fontFamily="monospace" android:clickable="true" android:focusable="true"
                android:background="?selectableItemBackground" />

            <TextView android:id="@+id/key_tab"
                android:layout_width="wrap_content" android:layout_height="match_parent"
                android:text="TAB" android:textColor="#CCCCCC" android:textSize="11sp"
                android:gravity="center" android:paddingHorizontal="12dp"
                android:fontFamily="monospace" android:clickable="true" android:focusable="true"
                android:background="?selectableItemBackground" />

            <TextView android:id="@+id/key_ctrl"
                android:layout_width="wrap_content" android:layout_height="match_parent"
                android:text="CTRL" android:textColor="#CCCCCC" android:textSize="11sp"
                android:gravity="center" android:paddingHorizontal="12dp"
                android:fontFamily="monospace" android:clickable="true" android:focusable="true"
                android:background="?selectableItemBackground" />

            <TextView android:id="@+id/key_arrow_up"
                android:layout_width="wrap_content" android:layout_height="match_parent"
                android:text="▲" android:textColor="#CCCCCC" android:textSize="14sp"
                android:gravity="center" android:paddingHorizontal="12dp"
                android:clickable="true" android:focusable="true"
                android:background="?selectableItemBackground" />

            <TextView android:id="@+id/key_arrow_down"
                android:layout_width="wrap_content" android:layout_height="match_parent"
                android:text="▼" android:textColor="#CCCCCC" android:textSize="14sp"
                android:gravity="center" android:paddingHorizontal="12dp"
                android:clickable="true" android:focusable="true"
                android:background="?selectableItemBackground" />

            <TextView android:id="@+id/key_arrow_left"
                android:layout_width="wrap_content" android:layout_height="match_parent"
                android:text="◀" android:textColor="#CCCCCC" android:textSize="14sp"
                android:gravity="center" android:paddingHorizontal="12dp"
                android:clickable="true" android:focusable="true"
                android:background="?selectableItemBackground" />

            <TextView android:id="@+id/key_arrow_right"
                android:layout_width="wrap_content" android:layout_height="match_parent"
                android:text="▶" android:textColor="#CCCCCC" android:textSize="14sp"
                android:gravity="center" android:paddingHorizontal="12dp"
                android:clickable="true" android:focusable="true"
                android:background="?selectableItemBackground" />

            <TextView android:id="@+id/key_home"
                android:layout_width="wrap_content" android:layout_height="match_parent"
                android:text="HOME" android:textColor="#CCCCCC" android:textSize="11sp"
                android:gravity="center" android:paddingHorizontal="12dp"
                android:fontFamily="monospace" android:clickable="true" android:focusable="true"
                android:background="?selectableItemBackground" />

            <TextView android:id="@+id/key_end"
                android:layout_width="wrap_content" android:layout_height="match_parent"
                android:text="END" android:textColor="#CCCCCC" android:textSize="11sp"
                android:gravity="center" android:paddingHorizontal="12dp"
                android:fontFamily="monospace" android:clickable="true" android:focusable="true"
                android:background="?selectableItemBackground" />

            <TextView android:id="@+id/key_pgup"
                android:layout_width="wrap_content" android:layout_height="match_parent"
                android:text="PGUP" android:textColor="#CCCCCC" android:textSize="11sp"
                android:gravity="center" android:paddingHorizontal="12dp"
                android:fontFamily="monospace" android:clickable="true" android:focusable="true"
                android:background="?selectableItemBackground" />

            <TextView android:id="@+id/key_pgdn"
                android:layout_width="wrap_content" android:layout_height="match_parent"
                android:text="PGDN" android:textColor="#CCCCCC" android:textSize="11sp"
                android:gravity="center" android:paddingHorizontal="12dp"
                android:fontFamily="monospace" android:clickable="true" android:focusable="true"
                android:background="?selectableItemBackground" />

        </LinearLayout>
    </HorizontalScrollView>

</LinearLayout>
