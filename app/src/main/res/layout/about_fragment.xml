<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <com.sentry.filemanager.ui.CoordinatorAppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?colorAppBarSurface"
        android:theme="?actionBarTheme"
        app:liftOnScroll="true"
        app:liftOnScrollTargetViewId="@id/scrollView">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?actionBarSize"
            app:popupTheme="?actionBarPopupTheme" />

    </com.sentry.filemanager.ui.CoordinatorAppBarLayout>

    <com.sentry.filemanager.ui.CoordinatorScrollingFrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:scrollbars="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/screen_edge_margin"
                android:clipToPadding="false"
                android:divider="@drawable/transparent_divider_vertical_16dp"
                android:orientation="vertical"
                android:showDividers="middle">

                <!-- App header card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardPreventCornerOverlap="false">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:paddingTop="24dp"
                        android:paddingBottom="16dp"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:src="@mipmap/launcher_icon"
                            android:scaleType="fitCenter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/app_name"
                            android:textAppearance="@style/TextAppearance.AppCompat.Headline"
                            android:layout_marginTop="12dp" />

                        <TextView
                            android:id="@+id/versionSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/app_version"
                            android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                            android:textColor="?android:textColorSecondary"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Links card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardPreventCornerOverlap="false">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingTop="@dimen/list_vertical_padding"
                        android:paddingBottom="@dimen/list_vertical_padding">

                        <!-- View Source Code -->
                        <me.zhanghai.android.foregroundcompat.ForegroundLinearLayout
                            android:id="@+id/gitHubLayout"
                            android:layout_width="match_parent"
                            android:layout_height="?listPreferredItemHeight"
                            android:paddingStart="?android:listPreferredItemPaddingStart"
                            android:paddingEnd="?android:listPreferredItemPaddingEnd"
                            android:foreground="?selectableItemBackground"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="@dimen/icon_size"
                                android:layout_height="@dimen/icon_size"
                                android:src="@drawable/github_icon_white_24dp"
                                app:tint="?colorControlNormal" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="@dimen/content_start_from_screen_edge_margin_minus_24dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="View Source Code"
                                    android:textAppearance="?textAppearanceListItem" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="GitHub Repository"
                                    android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                                    android:textColor="?android:textColorSecondary" />

                            </LinearLayout>

                        </me.zhanghai.android.foregroundcompat.ForegroundLinearLayout>

                        <!-- Release Notes -->
                        <me.zhanghai.android.foregroundcompat.ForegroundLinearLayout
                            android:id="@+id/releaseNotesLayout"
                            android:layout_width="match_parent"
                            android:layout_height="?listPreferredItemHeight"
                            android:paddingStart="?android:listPreferredItemPaddingStart"
                            android:paddingEnd="?android:listPreferredItemPaddingEnd"
                            android:foreground="?selectableItemBackground"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="@dimen/icon_size"
                                android:layout_height="@dimen/icon_size"
                                android:src="@drawable/text_file_icon_white_24dp"
                                app:tint="?colorControlNormal" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="@dimen/content_start_from_screen_edge_margin_minus_24dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Release Notes"
                                    android:textAppearance="?textAppearanceListItem" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="What's New"
                                    android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                                    android:textColor="?android:textColorSecondary" />

                            </LinearLayout>

                        </me.zhanghai.android.foregroundcompat.ForegroundLinearLayout>

                        <!-- Check for Updates -->
                        <me.zhanghai.android.foregroundcompat.ForegroundLinearLayout
                            android:id="@+id/checkUpdatesLayout"
                            android:layout_width="match_parent"
                            android:layout_height="?listPreferredItemHeight"
                            android:paddingStart="?android:listPreferredItemPaddingStart"
                            android:paddingEnd="?android:listPreferredItemPaddingEnd"
                            android:foreground="?selectableItemBackground"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="@dimen/icon_size"
                                android:layout_height="@dimen/icon_size"
                                android:src="@drawable/sync_icon_white_24dp"
                                app:tint="?colorControlNormal" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="@dimen/content_start_from_screen_edge_margin_minus_24dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Check for Updates"
                                    android:textAppearance="?textAppearanceListItem" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Check the latest version"
                                    android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                                    android:textColor="?android:textColorSecondary" />

                            </LinearLayout>

                        </me.zhanghai.android.foregroundcompat.ForegroundLinearLayout>

                        <!-- Change Log -->
                        <me.zhanghai.android.foregroundcompat.ForegroundLinearLayout
                            android:id="@+id/changelogLayout"
                            android:layout_width="match_parent"
                            android:layout_height="?listPreferredItemHeight"
                            android:paddingStart="?android:listPreferredItemPaddingStart"
                            android:paddingEnd="?android:listPreferredItemPaddingEnd"
                            android:foreground="?selectableItemBackground"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="@dimen/icon_size"
                                android:layout_height="@dimen/icon_size"
                                android:src="@drawable/history_icon_white_24dp"
                                app:tint="?colorControlNormal" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="@dimen/content_start_from_screen_edge_margin_minus_24dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Change Log"
                                    android:textAppearance="?textAppearanceListItem" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Track changes &amp; history"
                                    android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                                    android:textColor="?android:textColorSecondary" />

                            </LinearLayout>

                        </me.zhanghai.android.foregroundcompat.ForegroundLinearLayout>

                        <!-- Telegram -->
                        <me.zhanghai.android.foregroundcompat.ForegroundLinearLayout
                            android:id="@+id/telegramLayout"
                            android:layout_width="match_parent"
                            android:layout_height="?listPreferredItemHeight"
                            android:paddingStart="?android:listPreferredItemPaddingStart"
                            android:paddingEnd="?android:listPreferredItemPaddingEnd"
                            android:foreground="?selectableItemBackground"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="@dimen/icon_size"
                                android:layout_height="@dimen/icon_size"
                                android:src="@drawable/telegram_icon_white_24dp"
                                app:tint="?colorControlNormal" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="@dimen/content_start_from_screen_edge_margin_minus_24dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Contact Developer"
                                    android:textAppearance="?textAppearanceListItem" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="t.me/SentryFileManager"
                                    android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                                    android:textColor="?android:textColorSecondary" />

                            </LinearLayout>

                        </me.zhanghai.android.foregroundcompat.ForegroundLinearLayout>

                        <!-- Licenses -->
                        <me.zhanghai.android.foregroundcompat.ForegroundLinearLayout
                            android:id="@+id/licensesLayout"
                            android:layout_width="match_parent"
                            android:layout_height="?listPreferredItemHeight"
                            android:paddingStart="?android:listPreferredItemPaddingStart"
                            android:paddingEnd="?android:listPreferredItemPaddingEnd"
                            android:foreground="?selectableItemBackground"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="@dimen/icon_size"
                                android:layout_height="@dimen/icon_size"
                                android:src="@drawable/balance_icon_white_24dp"
                                app:tint="?colorControlNormal" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="@dimen/content_start_from_screen_edge_margin_minus_24dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Open Source Licenses"
                                    android:textAppearance="?textAppearanceListItem" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Third-party libraries"
                                    android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                                    android:textColor="?android:textColorSecondary" />

                            </LinearLayout>

                        </me.zhanghai.android.foregroundcompat.ForegroundLinearLayout>

                        <!-- About Sentry File Manager -->
                        <me.zhanghai.android.foregroundcompat.ForegroundLinearLayout
                            android:id="@+id/aboutSentryLayout"
                            android:layout_width="match_parent"
                            android:layout_height="?listPreferredItemHeight"
                            android:paddingStart="?android:listPreferredItemPaddingStart"
                            android:paddingEnd="?android:listPreferredItemPaddingEnd"
                            android:foreground="?selectableItemBackground"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="@dimen/icon_size"
                                android:layout_height="@dimen/icon_size"
                                android:src="@drawable/information_icon_white_24dp"
                                app:tint="?colorControlNormal" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="@dimen/content_start_from_screen_edge_margin_minus_24dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="About Sentry File Manager"
                                    android:textAppearance="?textAppearanceListItem" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Learn more about the project"
                                    android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                                    android:textColor="?android:textColorSecondary" />

                            </LinearLayout>

                        </me.zhanghai.android.foregroundcompat.ForegroundLinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </com.sentry.filemanager.ui.CoordinatorScrollingFrameLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
